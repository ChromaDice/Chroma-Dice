<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dice Roll</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bungee&family=Inter:wght@400;600;800&display=swap');
body{
  background:
    radial-gradient(circle at 20% 10%, #2d1b4e 0%, transparent 50%),
    radial-gradient(circle at 80% 90%, #0d3b3b 0%, transparent 50%),
    radial-gradient(circle at center, #1a0f2e 0%, #08051a 100%);
  font-family:'Inter',system-ui,sans-serif;
  min-height:100vh;
}
.header-font{font-family:'Bungee',system-ui;letter-spacing:4px;}

.dice{
  width:148px;height:148px;
  display:flex;align-items:center;justify-content:center;
  font-size:5rem;font-weight:800;color:white;
  letter-spacing:-2px;
  border-radius:28px;
  position:relative;
  cursor:default;
  transition:transform 0.2s cubic-bezier(0.4,0,0.2,1), box-shadow 0.2s ease;
  background-image:
    linear-gradient(155deg,
      rgba(255,255,255,0.18) 0%,
      rgba(255,255,255,0.04) 40%,
      transparent 60%,
      rgba(0,0,0,0.12) 100%);
  /* Realistic shadow stack PLUS a colored aura matching the die's color */
  box-shadow:
    0 1px 1px rgba(255,255,255,0.4) inset,
    0 -1px 1px rgba(0,0,0,0.15) inset,
    0 1px 2px rgba(0,0,0,0.2),
    0 4px 8px rgba(0,0,0,0.25),
    0 12px 24px rgba(0,0,0,0.35),
    0 24px 48px -8px rgba(0,0,0,0.4),
    0 0 40px -5px var(--die-glow, rgba(255,255,255,0.3)),
    0 0 80px -20px var(--die-glow, rgba(255,255,255,0.4));
  overflow:hidden;
  isolation:isolate;
  transform-origin:center center;
}
/* Top sheen highlight */
.dice::before{
  content:'';position:absolute;
  top:0;left:0;right:0;height:50%;
  background:linear-gradient(
    180deg,
    rgba(255,255,255,0.22) 0%,
    rgba(255,255,255,0.05) 50%,
    transparent 100%
  );
  pointer-events:none;
  border-radius:28px 28px 0 0;
  z-index:1;
}
/* Pip dots in the four corners */
.dice::after{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(circle at 18% 18%, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0.35) 4%, transparent 5%),
    radial-gradient(circle at 82% 18%, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.3) 4%, transparent 5%),
    radial-gradient(circle at 18% 82%, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.3) 4%, transparent 5%),
    radial-gradient(circle at 82% 82%, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0.35) 4%, transparent 5%);
  pointer-events:none;
  border-radius:28px;
  z-index:1;
}
.dice span.die-letter{
  position:relative;z-index:2;
  font-weight:800;
  /* Neon multi-layered text shadow */
  text-shadow:
    0 1px 2px rgba(0,0,0,0.5),
    0 0 8px rgba(255,255,255,0.9),
    0 0 16px var(--die-glow, rgba(255,255,255,0.6)),
    0 0 32px var(--die-glow, rgba(255,255,255,0.4)),
    0 0 48px var(--die-glow, rgba(255,255,255,0.3));
}
.dice:hover:not(.rolling){
  transform:translateY(-3px);
  box-shadow:
    0 1px 1px rgba(255,255,255,0.4) inset,
    0 -1px 1px rgba(0,0,0,0.15) inset,
    0 2px 4px rgba(0,0,0,0.2),
    0 8px 16px rgba(0,0,0,0.3),
    0 20px 40px rgba(0,0,0,0.4),
    0 32px 64px -8px rgba(0,0,0,0.45),
    0 0 50px -5px var(--die-glow, rgba(255,255,255,0.5)),
    0 0 100px -20px var(--die-glow, rgba(255,255,255,0.5));
}
.dice.rolling{
  box-shadow:
    0 1px 1px rgba(255,255,255,0.4) inset,
    0 -1px 1px rgba(0,0,0,0.15) inset,
    0 4px 8px rgba(0,0,0,0.3),
    0 16px 32px rgba(0,0,0,0.4),
    0 0 60px -5px var(--die-glow, rgba(255,255,255,0.6)),
    0 0 120px -15px var(--die-glow, rgba(255,255,255,0.5));
}
.dice-container{perspective:1600px;}

.dice-wrap{
  position:relative;
  display:inline-block;
}
.dice-wrap::after{
  content:'';position:absolute;
  bottom:-14px;left:50%;
  transform:translateX(-50%);
  width:130px;height:14px;
  background:radial-gradient(ellipse, rgba(0,0,0,0.4), transparent 70%);
  filter:blur(3px);
  pointer-events:none;
  opacity:0;
  transition:opacity 0.3s ease;
  z-index:-1;
}
.dice-wrap.rolling::after{opacity:1;}

.mini-die{
  width:58px;height:58px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.85rem;font-weight:900;color:white;
  border-radius:12px;
  text-shadow:0 2px 6px rgba(0,0,0,0.7);
  box-shadow:
    inset 0 5px 10px -2px rgba(255,255,255,0.45),
    inset 0 -5px 10px -2px rgba(0,0,0,0.55),
    0 0 0 4px rgba(255,255,255,0.85),
    0 8px 16px -4px rgba(0,0,0,0.5);
  position:relative;
}
.mini-die.placeholder{
  background:rgba(255,255,255,0.04) !important;
  color:rgba(255,255,255,0.25);
  box-shadow:
    inset 0 0 0 2px rgba(255,255,255,0.1),
    0 0 0 4px rgba(255,255,255,0.08);
  font-size:1.5rem;
}

/* Steady clockwise spin in place — no other motion */
@keyframes throwAndLand{
  0%   {transform: rotate(0deg);}
  100% {transform: rotate(1440deg);}
}
.rolling{
  animation: throwAndLand 5000ms cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
}

.table-felt{
  background:
    radial-gradient(circle at 50% 35%, #0f766e 0%, #042f2e 70%, #022020 100%);
  box-shadow:
    inset 0 0 180px rgba(0,0,0,0.9),
    inset 0 0 60px rgba(20,184,166,0.15),
    0 0 100px rgba(20,184,166,0.3),
    0 30px 60px -15px rgba(0,0,0,0.6);
  border:14px solid #134e4a;
  border-radius:44px;
  position:relative;
}
.table-felt::before{
  content:'';position:absolute;inset:14px;
  border:2px dashed rgba(20,184,166,0.2);
  border-radius:32px;
  pointer-events:none;
}

.control-btn{transition:all 0.2s cubic-bezier(0.4,0,0.2,1);}
.control-btn:hover{transform:translateY(-3px);box-shadow:0 25px 30px -8px rgba(0,0,0,0.3);}
.control-btn:active{transform:translateY(-1px);}

.crypto-badge{
  background:linear-gradient(135deg, rgba(20,184,166,0.15), rgba(168,85,247,0.15));
  border:1px solid rgba(20,184,166,0.4);
}
</style>
</head>
<body class="flex items-center justify-center p-6 text-white">
<div class="max-w-5xl w-full mx-auto">

  <div class="text-center mb-10">
    <h1 class="header-font text-5xl md:text-6xl text-transparent bg-clip-text bg-gradient-to-r from-teal-300 via-cyan-200 to-purple-300 drop-shadow-2xl">CHROMA ROLL</h1>
    <div class="mt-5 inline-flex items-center gap-x-3 crypto-badge text-white text-base md:text-lg font-bold px-8 py-4 rounded-3xl shadow-2xl backdrop-blur-md">
      <span class="text-2xl">🔐</span>
      <span>100% UNRIGGABLE</span>
      <span class="text-teal-400">•</span>
      <span>TRULY RANDOM</span>
      <span class="text-purple-400">•</span>
      <span>GAME READY</span>
      <span class="text-2xl">🎲</span>
    </div>
    <p class="text-teal-400/90 text-lg mt-4 tracking-[0.3em]">4 DICE · 6 COLORS · POWERED BY Math.random()</p>
  </div>

  <div class="table-felt p-10 md:p-14 shadow-2xl mb-6">
    <div id="dice-row" class="dice-container flex justify-center gap-8 md:gap-12 flex-wrap"></div>
  </div>

  <div id="prev-roll-banner" class="mb-6 bg-slate-900/70 backdrop-blur-xl rounded-3xl px-8 py-6 border border-amber-500/40 shadow-2xl">
    <p class="text-amber-300 text-sm font-bold tracking-[0.3em] text-center mb-4">⬅ PREVIOUS ROLL</p>
    <div id="prev-roll-dice" class="flex justify-center gap-5 flex-wrap"></div>
  </div>

  <!-- Possible colors legend -->
  <div class="mb-10 bg-slate-900/70 backdrop-blur-xl rounded-3xl px-8 py-6 border border-purple-500/40 shadow-2xl">
    <p class="text-purple-300 text-sm font-bold tracking-[0.3em] text-center mb-4">🎯 POSSIBLE COLORS · PICK YOUR FAVORITE</p>
    <div id="possible-colors" class="flex justify-center gap-5 flex-wrap"></div>
  </div>

  <div class="flex flex-wrap justify-center items-center gap-5">
    <button onclick="rollAllDice()" class="control-btn group px-14 py-7 bg-gradient-to-r from-teal-500 via-teal-400 to-teal-500 hover:from-teal-400 hover:to-teal-400 text-white font-bold text-4xl rounded-3xl shadow-2xl flex items-center gap-5">
      <span class="text-5xl group-active:rotate-12 transition-transform">🎲</span> ROLL ALL <span class="text-5xl group-active:-rotate-12 transition-transform">🎲</span>
    </button>
    <button onclick="toggleMute()" id="mute-btn" class="control-btn px-7 py-7 bg-slate-800 hover:bg-slate-700 text-3xl rounded-3xl shadow-xl">🔊</button>
    <div class="flex items-center gap-3 bg-slate-900/70 px-6 py-4 rounded-3xl backdrop-blur-sm">
      <span class="text-2xl">🔈</span>
      <input type="range" id="volume-slider" min="0" max="100" value="70" class="w-36 accent-teal-400 cursor-pointer">
      <span id="volume-value" class="font-mono text-base w-10">70%</span>
    </div>
    <button onclick="resetDice()" class="control-btn px-9 py-7 bg-slate-800 hover:bg-slate-700 text-white font-semibold text-2xl rounded-3xl shadow-xl">RESET</button>
  </div>

  <div class="text-center mt-10 text-teal-400/40 text-xs font-mono tracking-widest">throw · bounce · land · Math.random() · uniform distribution · TT Credits: @SaintAlive</div>
</div>

